add_namespace = mcksp_debug

# DEBUG: democratic + communism подыдеологии. Запуск: event mcksp_debug.1
country_event = {
	id = mcksp_debug.1
	title = mcksp_debug.1.t
	desc = mcksp_debug.1.desc

	is_triggered_only = yes

	option = {
		name = mcksp_debug.1.a
		set_politics = { ruling_party = democratic elections_allowed = no }
		set_party_name = { ideology = democratic long_name = mcksp_uds_party_long name = mcksp_uds_party }
		promote_character = SOV_nikita_iakushin
	}
	option = {
		name = mcksp_debug.1.b
		set_politics = { ruling_party = democratic elections_allowed = no }
		set_party_name = { ideology = democratic long_name = mcksp_lcl_party_long name = mcksp_lcl_party }
		promote_character = SOV_arseny_pavlov
	}
	option = {
		name = mcksp_debug.1.c
		set_politics = { ruling_party = democratic elections_allowed = no }
		set_party_name = { ideology = democratic long_name = mcksp_cdu_party_long name = mcksp_cdu_party }
		promote_character = SOV_stepan_pavlov
	}
	option = {
		name = mcksp_debug.1.d
		set_politics = { ruling_party = communism elections_allowed = no }
		set_party_name = { ideology = communism long_name = mcksp_neu_party_long name = mcksp_neu_party }
		promote_character = SOV_demokrit_ikonomidi
	}
	option = {
		name = mcksp_debug.1.cancel
	}
}


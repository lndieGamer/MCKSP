	id = mcksp_debug.2
	title = mcksp_debug.2.t
	desc = mcksp_debug.2.desc

	is_triggered_only = yes

	option = {
		name = mcksp_debug.2.a
		set_politics = { ruling_party = neutrality elections_allowed = no }
		set_party_name = { ideology = neutrality long_name = mcksp_boc_party_long name = mcksp_boc_party }
		promote_character = SOV_gleb_rychkov
	}
	option = {
		name = mcksp_debug.2.b
		set_politics = { ruling_party = neutrality elections_allowed = no }
		set_party_name = { ideology = neutrality long_name = mcksp_usp_party_long name = mcksp_usp_party }

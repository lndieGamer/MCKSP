	}
	option = {
		name = mcksp_debug.2.c
		set_politics = { ruling_party = neutrality elections_allowed = no }
		set_party_name = { ideology = neutrality long_name = mcksp_uso_party_long name = mcksp_uso_party }
		promote_character = SOV_ilya_popov
	}
	option = {
		name = mcksp_debug.2.d
		set_politics = { ruling_party = neutrality elections_allowed = no }
		set_party_name = { ideology = neutrality long_name = mcksp_rsu_party_long name = mcksp_rsu_party }

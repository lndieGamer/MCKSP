		iconType = { name = "dot_stepan"   position = { x = 330 y = 207 } quadTextureSprite = "GFX_MCKSP_compass_dot_strip" frame = 5  pdx_tooltip = "MCKSP_PT_STEPAN" }
		iconType = { name = "dot_ivan"     position = { x = 312 y = 171 } quadTextureSprite = "GFX_MCKSP_compass_dot_strip" frame = 6  pdx_tooltip = "MCKSP_PT_IVAN" }

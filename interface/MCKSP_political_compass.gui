	# Золотая подсветка строки легенды УДАЛЕНА (мёртвый код). Игрок выделяется жёлтым
	# текстом имени+идеологии своей строки (loc mcksp_legnm_*/mcksp_legid_* + GetSelfClr_*).

	# Пульс-подсказка на 4 ядрах: виден только в фазе 0 (выбор фракции). Гейт —
	# scripted_gui MCKSP_pulse_* (SOV_compass_open + mcksp_phase_0). Центр glow 36px
	# на точке: top-left = точка-11. Ядра: nikita(реформ) evgeny(гос) stepan(центр) demokrit(соц).
	# INSTANT-ОКНА (position x=0, без show/hide-анимации): появляются сразу на месте,
	# на выборе фракции (mcksp_phase_0 -> false) ИСЧЕЗАЮТ МГНОВЕННО в месте, не уезжая влево.
	# ВЫБОР АВТОРА: slide-вход НЕ совместим с instant-выходом на одном окне HOI4 — движок
	# сбрасывает окно в базовый position только по завершении hide-анимации, значит для
	# выезда нужен hide_animation_type, но он же даёт выезд-влево на скрытии (выбор фракции).
	# Dual-трюк (как у ореолов) тут не спасает: скрытие гонит флаг mcksp_phase_0 в один тик,
	# нет промежуточного кадра для передачи slide->instant, и в движке нет суб-секундного
	# таймера. Приоритет — мгновенное исчезновение на пике; вход без выезда принят как цена.
	containerWindowType = { name = "pulse_nikita_win"   position = { x = 0 y = 0 } size = { width = 602 height = 700 } clipping = no iconType = { name = "pulse" position = { x = 247 y = 322 } quadTextureSprite = "GFX_MCKSP_core_pulse" alwaystransparent = yes } }

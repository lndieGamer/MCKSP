###############################################################################
#  MCKSP — Политический компас (политические координаты)
#  Файл: interface/MCKSP_political_compass.gui
#
#  Самостоятельные окна, не привязаны к countrypoliticsview. Видимостью
#  управляет scripted_gui (см. одноимённый .txt).
#
#  Координаты позиций — абсолютные экранные.
#  countrypoliticsview сидит на абсолюте (-6, 78), ширина 550 → правый край ~544.
#
#  Координаты восьмёрки на компасе ЗАФИКСИРОВАНЫ. Формула пикселя
#  (шаг сетки 18px при поле 360px на ось −10..+10):
#       x = PLOT_CX + econ*18 - 7          (PLOT_CX = 220)
#       y = PLOT_CY - soc *18 - 7          (PLOT_CY = 250, +соц вверх)
###############################################################################

guiTypes = {

	# --------------------------------------------------------------------------
	# КНОПКА-СТРЕЛКА. Прикрепляется к countrypoliticsview через scripted_gui
	# (parent_window_name) — поэтому появляется/исчезает вместе с панелью политики.
	# Координаты ОТНОСИТЕЛЬНЫЕ к origin панели политики:
	#   x=540 — правый край списка партий (326+214=540)
	#   y=312 — на одной линии со списком
	# --------------------------------------------------------------------------
	# Два отдельных контейнера для кнопок-стрелок ►/◄, потому что scripted_gui
	# гейтит видимость целого окна (window_name), а не buttonType внутри него.
	# Оба окна позиционируются одинаково — визуально кнопка одна, переключаются
	# взаимно через scripted_gui visible.
	containerWindowType = {
		name = "MCKSP_compass_button_window_open"
		position = { x = 540 y = 312 }
		size = { width = 26 height = 46 }
		clipping = no

		buttonType = {
			name = "MCKSP_open_compass"
			position = { x = 0 y = 0 }
			quadTextureSprite = "GFX_MCKSP_compass_arrow_button"
			pdx_tooltip = "MCKSP_COMPASS_BUTTON_TT"
			clicksound = click_default
		}
	}

	containerWindowType = {
		name = "MCKSP_compass_button_window_close"
		position = { x = 540 y = 312 }
		size = { width = 26 height = 46 }
		clipping = no

		buttonType = {
			name = "MCKSP_close_compass"
			position = { x = 0 y = 0 }
			quadTextureSprite = "GFX_MCKSP_compass_arrow_button_close"
			pdx_tooltip = "MCKSP_COMPASS_BUTTON_TT"
			clicksound = click_close
		}
	}

	# --------------------------------------------------------------------------
	# VIEWPORT-КОНТЕЙНЕР. Пустой top-level контейнер с clipping=yes у правой
	# грани countrypoliticsview. Окно компаса прикрепляется к нему через
	# scripted_gui (parent_window_name) — тогда engine применяет клипинг,
	# и видимость компаса гейтится флагом независимо от viewport.
	# --------------------------------------------------------------------------
	containerWindowType = {
		name = "MCKSP_compass_viewport"
		position = { x = 564 y = 80 }		# абсолютные коорд: вплотную справа от countrypoliticsview
		size = { width = 602 height = 700 }	# +30% к ширине; вмещает длинные названия идеологий
		clipping = yes
	}

	# --------------------------------------------------------------------------
	# ОКНО КОМПАСА. Top-level в .gui, но scripted_gui привязывает его как
	# дочернее к viewport (parent_window_name="MCKSP_compass_viewport").
	# Координаты тогда относительные к viewport:
	#   position (-460,0) — полностью обрезано viewport-ом слева
	#   show_position (0,0) — полностью видно, совпадает с viewport
	# --------------------------------------------------------------------------
	containerWindowType = {
		name = "MCKSP_compass_window"
		position      = { x = -602 y = 0 }
		show_position = { x = 0    y = 0 }
		show_animation_type = decelerated
		hide_animation_type = accelerated
		animation_time = 300
		size = { width = 602 height = 700 }
		show_sound = open_sub_window

		background = {
			name = "Background"
			quadTextureSprite = "GFX_tiled_plain_bg"
		}

		# --- шапка ---
		iconType = {
			name = "header_bg"
			spriteType = "GFX_MCKSP_compass_header_bg"
			position = { x = 1 y = 5 }
			Orientation = "UPPER_LEFT"
		}
		instantTextboxType = {
			name = "title"
			position = { x = 37 y = 7 }
			font = "hoi_36header"
			text = "MCKSP_COMPASS_TITLE"
			maxWidth = 360
			maxHeight = 20
			format = left
		}
		buttonType = {
			name = "close_button"
			position = { x = -40 y = 7 }
			quadTextureSprite = "GFX_closebutton"
			shortcut = "ESCAPE"
			Orientation = "UPPER_RIGHT"
			clicksound = click_close
			pdx_tooltip = "CLOSE"
		}

		# --- поле компаса (сетка центрирована в ширине 602; центр x=301) ---
		iconType = {
			name = "compass_grid"
			position = { x = 121 y = 70 }
			quadTextureSprite = "GFX_MCKSP_compass_grid_360"
		}

		# Подписи осей. AUTH/LIB сверху/снизу по центру сетки. LEFT/RIGHT
		# вынесены ЗА поле координат (слева/справа от сетки).
		instantTextboxType = { name = "ax_top"    position = { x = 231 y = 54  } font = "hoi_16mbs" text = "MCKSP_AXIS_AUTH"  maxWidth = 140 format = center alwaystransparent = yes }
		instantTextboxType = { name = "ax_bottom" position = { x = 231 y = 432 } font = "hoi_16mbs" text = "MCKSP_AXIS_LIB"   maxWidth = 140 format = center alwaystransparent = yes }

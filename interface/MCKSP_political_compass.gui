		# --- 10 точек (формула: x = 301 + эко*18 - 7, y = 250 - соц*18 - 7) ---
		iconType = { name = "dot_nikita"   position = { x = 258 y = 333 } quadTextureSprite = "GFX_MCKSP_compass_dot_strip" frame = 1  pdx_tooltip = "MCKSP_PT_NIKITA" }
		iconType = { name = "dot_arseny"   position = { x = 276 y = 315 } quadTextureSprite = "GFX_MCKSP_compass_dot_strip" frame = 2  pdx_tooltip = "MCKSP_PT_ARSENY" }
		iconType = { name = "dot_demokrit" position = { x = 204 y = 225 } quadTextureSprite = "GFX_MCKSP_compass_dot_strip" frame = 3  pdx_tooltip = "MCKSP_PT_DEMOKRIT" }

###############################################################################
#  MCKSP — Политический компас (политические координаты)
#  Файл: interface/MCKSP_political_compass.gui
#
#  Все компас-окна объявлены TOP-LEVEL — engine не находит nested-контейнеры
#  для scripted_gui через window_name (проверено: "Window MCKSP_compass_viewport
#  not found" при попытке вложить в countrypoliticsview override).
#
#  Кнопки-стрелки ►/◄ парентятся к countrypoliticsview через parent_window_name
#  в scripted_gui — появляются/исчезают вместе с panel политики. viewport и
#  compass_window top-level: остаются видимы пока флаг SOV_compass_open стоит,
#  даже после закрытия panel политики (мелкий косметический баг — listener на
#  close_button vanilla окна ре-инстансит окно как дубль, поэтому не используем).
###############################################################################

guiTypes = {

	# Две стрелки ►/◄ — взаимоисключающие через scripted_gui visible / флаг
	# SOV_compass_open. Координаты relative к politicsview (parent_window_name).
	containerWindowType = {
		name = "MCKSP_compass_button_window_open"
		position = { x = 540 y = 312 }
		size = { width = 26 height = 46 }
		clipping = no

		buttonType = {
			name = "MCKSP_open_compass"
			position = { x = 0 y = 0 }
			quadTextureSprite = "GFX_MCKSP_compass_arrow_button"
			pdx_tooltip = "MCKSP_COMPASS_BUTTON_TT"
			clicksound = click_default
		}
	}

	containerWindowType = {
		name = "MCKSP_compass_button_window_close"
		position = { x = 540 y = 312 }
		size = { width = 26 height = 46 }
		clipping = no

		buttonType = {
			name = "MCKSP_close_compass"
			position = { x = 0 y = 0 }
			quadTextureSprite = "GFX_MCKSP_compass_arrow_button_close"
			pdx_tooltip = "MCKSP_COMPASS_BUTTON_TT"
			clicksound = click_close
		}
	}

	# Viewport top-level (абсолютные коорд). clipping=yes отрезает выезжающее окно.
	containerWindowType = {
		name = "MCKSP_compass_viewport"
		position = { x = 564 y = 80 }
		size = { width = 602 height = 700 }
		clipping = yes
	}

	# Окно компаса парентится к viewport через scripted_gui. position/show_position
	# relative к viewport: (-602,0) скрыто слева, (0,0) видно.
	containerWindowType = {
		name = "MCKSP_compass_window"
